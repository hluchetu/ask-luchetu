# LLM Providers
ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
DEEPSEEK_API_KEY=your_key_here
GOOGLE_API_KEY=your_key_here
OLLAMA_BASE_URL=http://localhost:11434

# LLM provider: anthropic | openai | deepseek | gemini | ollama
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat

# Search
TAVILY_API_KEY=tvly-your_key_here

# Database (Supabase — get connection string from supabase.com project settings)
DATABASE_URL=postgresql+asyncpg://postgres:[password]@[host].supabase.co:5432/postgres

# Observability
OBSERVABILITY_ENABLED=false
OBSERVABILITY_PROVIDER=langfuse
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
